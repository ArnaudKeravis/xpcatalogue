    "generate:solution-ocr": "python3 scripts/ocr_solution_descriptions.py",
    "sync:solution-heroes": "python3 scripts/sync_solution_hero_images.py",
    "generate:moment-persona-top": "python3 scripts/generate_moment_persona_top_from_excel.py",
    "ingest:personae-journey": "python3 scripts/ingest_personae_journey_excel.py"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "14.2.18",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
