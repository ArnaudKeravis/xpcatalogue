{
  "name": "experience-catalogue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:open": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ci:verify-excel-so": "bash scripts/ci-verify-excel-so.sh",
