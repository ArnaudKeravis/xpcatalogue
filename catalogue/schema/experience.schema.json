{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/experience.schema.json",
  "title": "AI Experience",
  "type": "object",
  "required": [
    "id",
    "title",
    "owner",
    "intent",
    "model",
    "inputs",
    "prompt_strategy",
    "output_contract",
    "quality",
    "lifecycle",
    "examples"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "intent": {
      "type": "string",
      "minLength": 10
    },
    "model": {
      "type": "object",
      "required": [
        "provider",
        "name",
        "temperature"
      ],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "description",
          "required"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "prompt_strategy": {
      "type": "object",
      "required": [
        "system_instructions",
        "user_template",
        "constraints"
      ],
      "additionalProperties": false,
      "properties": {
        "system_instructions": {
          "type": "string",
          "minLength": 20
        },
        "user_template": {
          "type": "string",
          "minLength": 20
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "output_contract": {
      "type": "object",
      "required": [
        "format",
        "must_include",
        "must_not_include"
      ],
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string"
        },
        "must_include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_not_include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "required": [
        "kpis",
        "failure_modes",
        "review_required"
      ],
      "additionalProperties": false,
      "properties": {
        "kpis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_required": {
          "type": "boolean"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": [
        "status",
        "last_reviewed"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "validated",
            "deprecated"
          ]
        },
        "last_reviewed": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "input",
          "output_excerpt"
        ],
        "additionalProperties": false,
        "properties": {
          "input": {
            "type": "string"
          },
          "output_excerpt": {
            "type": "string"
          }
        }
      }
    }
  }
}
